# Server
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=Doclyze

# AI providers — at least one required for summaries
# OpenAI GPT-3.5 (primary)
OPENAI_API_KEY=your_openai_api_key_here
# Google Gemini 2.0 Flash (fallback if OpenAI fails)
# Add up to 3 keys — rotates automatically on rate limit (429)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_second_gemini_key_here
GEMINI_API_KEY_3=your_third_gemini_key_here

# Google Vision API — for OCR on images and scanned PDFs
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# Public API key — sent by callers as x-api-key header
# Set to any strong secret string
API_KEY=your_secret_api_key_here
